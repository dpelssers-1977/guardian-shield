{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "0.1.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "nl",

  "author": "Guardian Shield Contributors",
  "homepage_url": "https://github.com/dpelssers-1977/guardian-shield",

  "browser_specific_settings": {
    "gecko": {
      "id": "guardian-shield@guardianshield.org",
      "strict_min_version": "115.0"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "__MSG_extensionName__"
  },

  "background": {
    "scripts": ["background/service-worker.js"],
    "type": "module"
  },

  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "downloads",
    "webNavigation",
    "scripting"
  ],

  "optional_permissions": [
    "history",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/site-analyzer.js",
        "content/link-hover.js"
      ],
      "css": [],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content/gmail-scanner.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": [
        "content/outlook-scanner.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    {
      "resources": [
        "alerts/phishing-warning.html",
        "alerts/unsafe-download.html",
        "alerts/alerts.css",
        "data/*.json",
        "icons/*.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
