# ============================================================
# Guardian Shield — Environment Configuration
# Bestandslocatie in project: /guardian-shield/.env.example
# ============================================================
# Kopieer dit bestand naar .env en vul je eigen waarden in:
#   cp .env.example .env
#
# BELANGRIJK: .env staat in .gitignore — wordt NOOIT gecommit!
# ============================================================

# ----- Algemeen -----
# Taal: nl, fr, en, de
GS_LANGUAGE=nl
# Log niveau: debug, info, warning, error
GS_LOG_LEVEL=info
# Poort voor de lokale backend API
GS_BACKEND_PORT=7777
# Geheime sleutel voor interne communicatie extension <-> backend
GS_INTERNAL_SECRET=VERANDER-DIT-NAAR-EEN-WILLEKEURIGE-STRING

# ----- Threat Intelligence API Keys (allemaal optioneel & gratis) -----
# PhishTank: https://phishtank.com/api_info.php
PHISHTANK_API_KEY=
# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
# AlienVault OTX: https://otx.alienvault.com/api
ALIENVAULT_OTX_KEY=
# Google Safe Browsing: https://developers.google.com/safe-browsing
GOOGLE_SAFE_BROWSING_KEY=
# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=
# Shodan: https://account.shodan.io/
SHODAN_API_KEY=

# ----- Update Server -----
# URL waar ondertekende updates worden gepubliceerd
GS_UPDATE_SERVER_URL=https://guardianshield.github.io/updates
# Update frequentie in uren (standaard: 24 = dagelijks)
GS_UPDATE_INTERVAL_HOURS=24

# ----- Lokale AI-Assistent (Fase 8) -----
# Ollama host (standaard: lokaal)
OLLAMA_HOST=http://localhost:11434
# AI model naam (aanbevolen: llama3.1:8b of phi3:mini voor minder krachtige systemen)
OLLAMA_MODEL=llama3.1:8b
# ChromaDB pad voor vector store
CHROMA_DB_PATH=./data/vectorstore

# ----- Backend Scanner Instellingen -----
# Maximaal aantal gelijktijdige scans
GS_MAX_CONCURRENT_SCANS=4
# Scan timeout in seconden
GS_SCAN_TIMEOUT=300
# Honeypot bestanden map (ransomware detectie)
GS_HONEYPOT_DIR=~/.guardian-shield/honeypots

# ----- Dashboard -----
# Dashboard poort
GS_DASHBOARD_PORT=3000
# WebSocket poort voor real-time updates
GS_WEBSOCKET_PORT=7778

# ----- Notificaties -----
# Desktop notificaties inschakelen (true/false)
GS_NOTIFICATIONS_ENABLED=true
# Geluid bij kritieke waarschuwingen (true/false)
GS_NOTIFICATION_SOUND=true
